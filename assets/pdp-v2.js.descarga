var htmxCallTriggered = false;
function addEventHandlerToRemoveHxTrigger() {
  var element = document.getElementById('product-details-tableview-lightbox');
  if (element) {
    element.addEventListener('htmx:afterSwap', function (event) {
      event.target.removeAttribute('hx-trigger');
      event.target.removeAttribute('hx-get');
      event.target.removeAttribute('hx-target');
      event.target.removeAttribute('hx-swap');
      htmx.process(htmx.find('#product-details-tableview-lightbox'));
      htmxCallTriggered = true;

    });
    element.addEventListener('htmx:responseError', function (event) {
      var loaderElement = document.getElementById('pdp-tv-loader');
      if (loaderElement) {
        loaderElement.remove();
      }
      var errorMessage = document.getElementById('pdp-tv-error-message')
      if (errorMessage) {
        errorMessage.innerText = "Sorry, we are unable to get items.";
      }
    });
  }

}


const tvPs = (tvPsArray) => {
  if (!Array.isArray(tvPsArray)) return false
  for (part in tvPsArray) {
    let currentPart = tvPsArray[part]
    up(currentPart)
    tp(currentPart)
    vi(currentPart)
    ca(currentPart)
  }
  resizeFeaturedItemTableCells()
}

const up = (currentPart) => {
