function removeNonCurrencyCharacters(input) {
  return input.replace(/[^0-9$.]/g, '');
}

/**
 * @description used to validate the user entered zipcode
 * @param {*} event 
 * @returns {undefined}
 */
function validateZipCode(event) {
  const zipCodeElm = event.target.parentElement.querySelector("input");
  if (!zipCodeElm?.value || zipCodeElm?.value?.length < 5) {
    zipCodeElm.setCustomValidity("Enter Valid zip code");
    event?.preventDefault();
    return;
  } else {
    zipCodeElm.setCustomValidity("");
    event?.target?.setAttribute('data-state', 'loading')
  }
}

/**
 * @description function used to hide shipping estimate message and to show zipcode
 */
function toggleZipInputVisibility() {
  sendLinkEvent({
    event_name: 'pdp delivery date click',
    ui_link_name: 'edit'
  })
  document
    .getElementById("edd-shipto-container")
    .classList.add("hidden");
  document
    .getElementById("edd-enter-zipcode-container")
    .classList.remove("hidden");
  document
    .querySelector("#edd-enter-zipcode-container p")
    ?.classList.add("hidden");
}

/**
 * @description function use to stop zipcode length less than given max length
 * @param {*} event 
 */
function validateOnInput(event) {
  if (event.target?.value.length > event.target.maxLength)
    event.target.value = event.target?.value.slice(0, event.target.maxLength);
  event.target?.setCustomValidity('')
}

function validateQtyAndLenthForEstimate(event) {
  const zipcodeElm = f("#add-zip-code");
  const defaultZipCode = f("#estimate_default_zip_code");
  const isCTL = event?.target?.dataset?.ctl;
  if (isCTL === "true" || !zipcodeElm.checkValidity()) {
    event.preventDefault();
    return;
  }
  if (
    (zipcodeElm?.value === "" || zipcodeElm?.value === 0) &&
    defaultZipCode?.value === ""
  ) {
    event.preventDefault();
    return;
  }
  if (!f('#edd-enter-zipcode-container')?.classList?.contains('hidden')) {
    f('#btn-edd-apply')?.setAttribute("data-state", "loading");
  }
}
function getEstimatePayload() {
  const zipCode = f("#add-zip-code")?.value;
  const defaultZipCode = zipCode === '' || zipCode === 0 ? f("#estimate_default_zip_code")?.value : zipCode;
  return {
    referenceNumber: f("#referenceNumber")?.value,
    "quantity-new": f("#pdp-input-quantity")?.value || f("#quantity")?.value || f("#pdp-quantity")?.value,
    "pdp-input-length": f("#pdp-input-length")?.value,
    zipCode: defaultZipCode
  };
}

function extractNumber(text) {
  const match = text.match(/\d+\.\d+/);
  if (match) {
    return match[0];
  }
  return null;
}

function getCurrentItemDataFromPDP() {
  let itemCell = document.getElementById("pdp-tv-item-number") ?? '';
  let elemWithItemNumber = document.getElementById("basePartNumber") ?? '';
  let itemNumber = elemWithItemNumber.getAttribute("data-partnumber") ?? '';
  itemCell.innerHTML = `<a href="/product/details/${itemNumber}" onclick="capturePdpClickAdobeEvent('${itemNumber}')">${itemNumber}</a>` ?? ''

  let availabilityCell = document.getElementById("pdp-tv-inventory") ?? '';
  let elemWithStockInfo = document.getElementById("availabilityHtml") ?? '';
  availabilityCell.innerHTML = elemWithStockInfo.innerHTML ?? '';
  removeThirdPTagFromInventoryCell()

  let unitPriceCell = document.getElementById("pdp-tv-unit-price") ?? '';
  let elemWithUnitPrice = document.getElementById("webPriceId") ?? '';
  let unitPriceDisplayText = elemWithUnitPrice.innerHTML ?? '';
  unitPriceCell.innerHTML = unitPriceDisplayText ?? '';

  let priceCell = document.getElementById("pdp-tv-price") ?? '';
  let elemWithPrice = document.getElementById("totalPriceId") ?? '';
  let price = elemWithPrice.getAttribute('data-initial-value')
  let minimumOrderQuantityElem = (document.getElementById("pdp-quantity") || document.getElementById("quantity")) ?? '';
  let minimumOrderQuantity = minimumOrderQuantityElem.getAttribute("data-minorderquantity") ?? '';
  priceCell.innerHTML = `${minimumOrderQuantity > 1 ? `${price}/pack of ${minimumOrderQuantity}` : `${price} ea.`}` ?? ''

  setAddToCartButtonHTMLForCurrentItem()

  let uniqueCells = document.querySelectorAll('td[id^="pdp-tv-col"]') ?? '';
  if (uniqueCells) {
    uniqueCells.forEach(tdElement => {
      let dataName = tdElement.getAttribute('data-name');
      let correspondingElement = document.getElementById(dataName) ?? '';
      if (correspondingElement) {
        tdElement.innerHTML = correspondingElement.getAttribute('data-value') ?? '';
      }
    });
  }
}

function getAddToCartCallForTVWidgetCurrentItem() {
  let addToCartBtnElement = document.getElementById("btn-pdp-add-to-cart") ?? '';
  let hxGetURL = addToCartBtnElement.getAttribute("hx-get") ?? '';

  let queryString = hxGetURL.split('?')[1] ?? '';
  let params = new URLSearchParams(queryString)

  let minimumOrderQuantityElem = (document.getElementById("pdp-quantity") || document.getElementById("quantity")) ?? '';
  let minimumOrderQuantity = minimumOrderQuantityElem.getAttribute("data-minorderquantity") ?? '';

  params.delete('addToCartSource')
  params.delete('inLightbox')
  params.delete('grow486')

  params.append('quantity', minimumOrderQuantity)
  params.append('addToCartSource', 'table%20view%20on%20pdp')
  params.append('inLightbox', 'true')


  let updateQueryString = params.toString()
  return hxGetURL.split('?')[0] + '?' + updateQueryString
}

function setAddToCartButtonHTMLForCurrentItem() {
  let addToCartCall = getAddToCartCallForTVWidgetCurrentItem()

  let cartActionCellHTML = `<div id="current-item-add-to-cart-button"> 
                                    <button 
                                        hx-get="${addToCartCall}"
                                        hx-swap="innerHTML"
                                        hx-target=this
                                    >
                                        <div class="pdp-tv-add-to-cart-btn btn btn-primary text-base rounded-2xl">Add <div id="toCartText"> to Cart </div></div>
                                    </button>
                            </div>`

  let cartActionCell = document.getElementById("pdp-tv-cart-action")
  cartActionCell.innerHTML = cartActionCellHTML
}

function removeThirdPTagFromInventoryCell() {
  const containerElement = document.getElementById("pdp-tv-inventory");
  if (containerElement) {
    const pTags = containerElement.querySelectorAll('p');
    if (pTags.length >= 3) {
      for (let i = 0; i < pTags.length; i++) {
        formatShippingText(pTags[i])
        if (i >= 2) {
          pTags[i].remove();
        }

      }
    }
  }
}

function showPdpTVLightbox() {
  f("#product-details-tableview-lightbox-stage").classList.remove("f-hidden")
  f("#product-details-tableview-lightbox-stage").classList.add('flex')
}

function closePdpTVLightbox() {
  f("#product-details-tableview-lightbox-stage").classList.add('f-hidden')
  f("#product-details-tableview-lightbox-stage").classList.remove('flex')

}

function formatShippingText(pTag) {
  const text = pTag.textContent.trim()
  if (text.includes("Expected to ship within")) {
    const match = text.match(/(\d+)\s*Business/)
    if (match) {
      const days = match[1];
      pTag.textContent = `Exp. to ship (${days} Biz. days)`
      pTag.style = 'line-height: 1.25rem'
    }
  }
}

function pdpTableviewAddToCart(addToCartUrl, targetElement) {
  htmx.ajax('GET', `${addToCartUrl}`, { target: targetElement, indicator: 'none' })
}

