const unloadLightboxCadAndLoadPdpCad = () => {
  if (cadLightboxActivated) {
    cds.cadViewer.dispose();
    cds.CADRequester.setContainerElementId('cds-cad-container');
    cds.CADRequester.webglViewerElementId = 'cds-cad-viewer-container';
    cds.CADRequester.webglIconsElementId = 'cds-icon-container';
    cds.CADRequester.load();
    cadLightboxActivated = false;
  }
}

// secondary images
const setThumbnailToSelected = (clickedElem) => {
  let thumbContainers = f('.thumbnail-image-container');
  let thumbImages = document.getElementsByClassName('thumbnail-image');
  let featuredVideo = document.getElementById('load-video');
  let borderClass = 'border-primary-variant-2';

  //var productVideo = document.querySelectorAll('#product-video-frame');
  //var product360 = document.querySelectorAll('#product-360-frame');

  // is
  const isDesiredThumbnailType = (thumbnailElem, desiredType) => {
    if (!thumbnailElem) return false;
    return thumbnailElem.getAttribute('data-thumbnail-type') == desiredType;
  }

  const isVideoThumbnail = (thumbnailElem) => {
    let desiredType = 'video';
    return isDesiredThumbnailType(thumbnailElem, desiredType);
  }

  const is360Thumbnail = (thumbnailElem) => {
    let desiredType = '360';
    return isDesiredThumbnailType(thumbnailElem, desiredType);
  }

  const isCadThumbnail = (thumbnailElem) => {
    let desiredType = 'cad';
    return isDesiredThumbnailType(thumbnailElem, desiredType);
  }

  // show
  const showProductImageFrame = () => {
    hideAllProductFrames();
    let elem = f('#product-image-frame');
    if (elem) elem.classList.remove('hidden');
  }

  const showProductVideoFrame = () => {
    hideAllProductFrames();
    let elem = f('#product-video-frame');
    if (elem) elem.classList.remove('hidden');
  }

  const showProduct360Frame = () => {
    hideAllProductFrames();
    let elem = f('#product-360-frame');
    if (elem) elem.classList.remove('invisible-position');
  }

  const showProductCadFrame = () => {
    hideAllProductFrames();
    let elem = f('#product-cad-frame');
    if (elem) elem.classList.remove('hidden');
  }

  // hide
  const hideProductImageFrame = () => {
    let elem = f('#product-image-frame');
    if (elem) elem.classList.add('hidden');
  }

  const hideProductVideoFrame = () => {
    let elem = f('#product-video-frame');
    if (elem) elem.classList.add('hidden');
  }

  const hideProduct360Frame = () => {
    let elem = f('#product-360-frame');
    if (elem) elem.classList.add('invisible-position');
  }

  const hideProductCadFrame = () => {
    let elem = f('#product-cad-frame');
    if (elem) elem.classList.add('hidden');
  }

  const hideAllProductFrames = () => {
    hideProductImageFrame();
    hideProductVideoFrame();
    hideProduct360Frame();
    hideProductCadFrame();
  }

  // border
  const removeBorderFromThumbContainers = () => {
    if (thumbContainers) thumbContainers.forEach((elem) => {
      elem.classList.remove(borderClass);
    });
    let imageThumbs = f('[data-product-image-index]');
    if (imageThumbs) imageThumbs.forEach((elem) => {
      elem.classList.remove(borderClass);
    });
  }

  const addBorderToSelectedThumb = (elem) => {
    removeBorderFromThumbContainers();
    if (elem) {
      if (Array.isArray(elem)) elem.forEach((thumb) => {
        thumb.classList.add(borderClass)
      });
      else elem.classList.add(borderClass);
    }
  }

  // video
  const setVideoIframeSrc = (currentThumbImage) => {
    featuredVideo.src = `https://www.youtube.com/embed/${currentThumbImage.alt}?rel=0`

  }

  const getSelectedImageThumbDataImageIndexElem = (elem) => {
    let dataAttributeName = 'data-product-image-index';
    let dataImageIndex = elem.getAttribute(dataAttributeName)
    if (dataImageIndex) {
      let dataImageIndexElem = f(`[${dataAttributeName}="${dataImageIndex}"]`);
      if (dataImageIndexElem) return dataImageIndexElem;
    }
    return false;
  }

  let currentThumbContainer = clickedElem;
  let currentThumbImage = clickedElem.querySelector('.thumbnail-image')
  if (currentThumbImage) {
    if (isVideoThumbnail(currentThumbContainer)) {
      showProductVideoFrame();
      addBorderToSelectedThumb(currentThumbContainer);
      setVideoIframeSrc(currentThumbImage);
    } else if (is360Thumbnail(currentThumbContainer)) {
      showProduct360Frame();
      addBorderToSelectedThumb(currentThumbContainer);
    } else if (isCadThumbnail(currentThumbContainer)) {
      showProductCadFrame();
      addBorderToSelectedThumb(currentThumbContainer);
    } else {
      let selectedThumbDataImageIndexElem = getSelectedImageThumbDataImageIndexElem(currentThumbContainer)
      addBorderToSelectedThumb(selectedThumbDataImageIndexElem);
      showProductImageFrame();
      setLightboxProductImage(currentThumbImage);
      selectProductImageLightboxTab('image');
    }
  }
}

const initZoomImage = () => {
  let img = document.querySelector('#image'); // Selected Images
  if (img === null) return; // Exit from this function, when there is no image for the product to zoom

  let zoomwindow = document.querySelector('#zoomwindow'); // Lens
  let zoomimage = document.querySelector('#zoomimage'); // Result Display
  let featuredImg = document.getElementById('image');
  const container = document.querySelector('#container');

  img.addEventListener('mousemove', moveView);
  zoomwindow.addEventListener('mousemove', moveView);
  container.addEventListener('mouseleave', handleMouseOut);

  let oW = zoomimage.offsetWidth / zoomwindow.offsetWidth;
  let oH = zoomimage.offsetHeight / zoomwindow.offsetHeight;

  zoomimage.style.backgroundImage = `url(${featuredImg.src})`;
  zoomimage.style.visibility = 'hidden';
  zoomwindow.style.visibility = 'hidden';
  zoomimage.style.backgroundSize = img.width * oW + 'px ' + img.height * oH + 'px';

  function handleMouseOut() {
    zoomimage.style.visibility = 'hidden';
    zoomwindow.style.visibility = 'hidden';
  }

  function moveView(e) {
    e.preventDefault();
    e = e || window.event;
    zoomwindow.style.visibility = 'visible';
    zoomimage.style.visibility = 'visible';
    let bounds = img.getBoundingClientRect();
    let x = e.pageX - bounds.left - window.scrollX - zoomwindow.offsetWidth / 2;
    if (x > img.width - zoomwindow.offsetWidth) {
      x = img.width - zoomwindow.offsetWidth;
    }
    if (x < 0) {
      x = 0;
    }
    zoomwindow.style.left = x + 'px';
    let y = e.pageY - bounds.top - window.scrollY - zoomwindow.offsetHeight / 2;
    if (y > img.height - zoomwindow.offsetHeight) {
      y = img.height - zoomwindow.offsetHeight;
    }
    if (y < 0) {
      y = 0;
    }
    zoomimage.style.backgroundSize =
      img.width * oW + "px " + img.height * oH + "px";
    zoomwindow.style.top = y + 'px';
    zoomimage.style.backgroundPosition = '-' + x * oW + 'px -' + y * oH + 'px';
  }
}

// used by both on page and lightbox thumbnails
// also sets zoom image box background
const setLightboxProductImage = (selectedThumbnailImg) => {
  if (!selectedThumbnailImg) return;

  // if api returns gif
  const switchImageToJpg = (imageSrc) => {
    if (!imageSrc || typeof imageSrc !== 'string') return '';
    return imageSrc.replace('.gif', '.jpg')
  }
  // featured product
  const setFeaturedProductImageSrc = (imageSrc) => {
    let featuredProductImage = f('#image');
    if (featuredProductImage) featuredProductImage.setAttribute('src', switchImageToJpg(imageSrc));
  }
  const setFeaturedProductImageLightboxSrc = (imageSrc) => {
    let lightboxProductImage = f('#product-images-lightbox-full-image');
    if (lightboxProductImage) lightboxProductImage.setAttribute('src', switchImageToJpg(selectedThumbnailImgSrc));
  }
  // zoom image
  const setZoomImageBackgroundImage = (productImageSrc) => {
    let zoomimage = f('#zoomimage');
    if (productImageSrc) zoomimage.style.backgroundImage = `url("${switchImageToJpg(productImageSrc)}")`;
  }

  // set
  const selectedThumbnailImgSrc = selectedThumbnailImg.getAttribute('src');
  setFeaturedProductImageSrc(selectedThumbnailImgSrc);
  setZoomImageBackgroundImage(selectedThumbnailImgSrc);
  setFeaturedProductImageLightboxSrc(selectedThumbnailImgSrc);
}

const selectProductImageLightboxTab = (tabType) => {
  if (!tabType || typeof tabType !== 'string') return;

  // show hide
  const showProductImageLightboxTab = () => {
    let productImageLightboxTabElem = f(`#product-details-lightbox-tab-${tabType}`);
    if (productImageLightboxTabElem) productImageLightboxTabElem.classList.remove('invisible-position');
  }
  const hideAllProductImageLightboxTabs = () => {
    let productImageLightboxTabs = f('.product-details-lightbox-tab');
    if (productImageLightboxTabs) productImageLightboxTabs.forEach((elem) => {
      elem.classList.add('invisible-position');
    });
  }
  const showProductDetailsImageLightboxImageThumbnails = () => {
    let productImageLightboxItemInfo = f('.product-details-image-lightbox-image-thumbnails');
    if (productImageLightboxItemInfo) productImageLightboxItemInfo.forEach((elem) => {
      elem.classList.remove('hidden');
    });
  }
  const showProductDetailsImageLightbox360ImageThumbnails = () => {
    let productImageLightboxItemInfo = f('.product-details-image-lightbox-360-image-thumbnails');
    if (productImageLightboxItemInfo) productImageLightboxItemInfo.forEach((elem) => {
      elem.classList.remove('hidden');
    });
  }
  const showVideoLightboxImageThumbnails = () => {
    let productImageLightboxItemInfo = f('.product-details-image-lightbox-video-thumbnails');
    if (productImageLightboxItemInfo) productImageLightboxItemInfo.forEach((elem) => {
      elem.classList.remove('hidden');
    });
  }

  const hideProductDetailsImageLightboxImageThumbnails = () => {
    let productImageLightboxItemInfo = f('.product-details-image-lightbox-image-thumbnails');
    if (productImageLightboxItemInfo) productImageLightboxItemInfo.forEach((elem) => {
      elem.classList.add('hidden');
    });
  }
  const hideProductDetailsImageLightbox360ImageThumbnails = () => {
    let productImageLightboxItemInfo = f('.product-details-image-lightbox-360-image-thumbnails');
    if (productImageLightboxItemInfo) productImageLightboxItemInfo.forEach((elem) => {
      elem.classList.add('hidden');
    });
  }
  const hideVideoLightboxImageThumbnails = () => {
    let productImageLightboxItemInfo = f('.product-details-image-lightbox-video-thumbnails');
    if (productImageLightboxItemInfo) productImageLightboxItemInfo.forEach((elem) => {
      elem.classList.add('hidden');
    });
  }

  const removeActiveFromAllProductImageLightboxTabButtons = () => {
    let productImageLightboxTabButtons = f('.product-details-lightbox-tab-button');
    if (productImageLightboxTabButtons) productImageLightboxTabButtons.forEach((elem) => {
      elem.classList.remove('active');
    });
  }
  const setProductImageLightboxTabButtonToActive = () => {
    let productLightboxTabButtonElem = f(`#product-details-lightbox-tab-button-${tabType}`);
    if (productLightboxTabButtonElem) {
      removeActiveFromAllProductImageLightboxTabButtons();
      productLightboxTabButtonElem.classList.add('active')
    }
  }
  // video
  const setVideoIframeSrc = () => {
    let lightboxVideoIframeElem = f('#load-video-lightbox');
    if (lightboxVideoIframeElem) {
      if (lightboxVideoIframeElem.getAttribute('src') === '') {
        let videoDataSrc = lightboxVideoIframeElem.getAttribute('data-video-src') || '';
        lightboxVideoIframeElem.setAttribute('src', videoDataSrc);
      }
    }
  }
  if (tabType === 'image') {
    setProductImageLightboxTabButtonToActive();
    hideAllProductImageLightboxTabs();
    showProductDetailsImageLightboxImageThumbnails();
    showProductImageLightboxTab();
    hideProductDetailsImageLightbox360ImageThumbnails()
    hideVideoLightboxImageThumbnails()
  }
  if (tabType === 'video') {
    //setVideoIframeSrc();
    setProductImageLightboxTabButtonToActive();
    hideAllProductImageLightboxTabs();
    hideProductDetailsImageLightboxImageThumbnails();
    showProductImageLightboxTab();
    hideProductDetailsImageLightbox360ImageThumbnails()
    showVideoLightboxImageThumbnails()
    //setVideoThumbnailToSelected()
  }
  if (tabType === '360') {
    setProductImageLightboxTabButtonToActive();
    hideAllProductImageLightboxTabs();
    hideProductDetailsImageLightboxImageThumbnails();
    showProductDetailsImageLightbox360ImageThumbnails()
    showProductImageLightboxTab();
    hideVideoLightboxImageThumbnails()
  }
  if (tabType === 'cad') {
    setProductImageLightboxTabButtonToActive();
    hideAllProductImageLightboxTabs();
    hideProductDetailsImageLightboxImageThumbnails();
    showProductImageLightboxTab();
    hideProductDetailsImageLightbox360ImageThumbnails()
    hideVideoLightboxImageThumbnails()
    if (typeof loadCadLightbox === 'function') loadCadLightbox();
    else console.log(`loadCadLightbox() error loading`)
  }
}

const setVideoThumbnailToSelected = (thumbnailIndex) => {
  const borderClass = 'border-primary-variant-2'
  const removeBorderFromAllNonVideoThumbnails = () => {
    let nonImageThumnailElems = f('[data-thumbnail-type]');
    if (nonImageThumnailElems) nonImageThumnailElems.forEach((elem) => {
      let dataThumbnailType = elem.getAttribute('data-thumbnail-type') || false;
      if (dataThumbnailType && dataThumbnailType !== 'video') elem.classList.remove(borderClass);
    })
  }
  const removeBorderFromAllVideoThumbnails = () => {
    let imageThumbnailElems = f(`[data-video-index]`);
    //removeBorderFromAllNonVideoThumbnails();
    if (imageThumbnailElems) imageThumbnailElems.forEach((elem) => {
      elem.classList.remove(borderClass);
    });
  }
  const addBorderToSelectedThumbnailImage = (thumbnail) => {
    if (thumbnail) thumbnail.forEach((elem) => {
      elem.classList.add(borderClass);
    });
  }

  const selectedThumbnail = f(`[data-video-index="${thumbnailIndex}"]`);

  setLightboxVideo(thumbnailIndex);
  removeBorderFromAllVideoThumbnails();
  addBorderToSelectedThumbnailImage(selectedThumbnail);
}

const setLightboxVideo = (thumbnailIndex) => {
  let videoIframe = document.getElementById('load-video-lightbox');
  let selectedThumbnail = f(`[data-video-index="${thumbnailIndex}"]`)[0];
  
  if (videoIframe && selectedThumbnail) {
    let videoDataSrc = selectedThumbnail.getAttribute('data-video-src') || '';
    videoIframe.setAttribute('src', videoDataSrc);
  }
}

