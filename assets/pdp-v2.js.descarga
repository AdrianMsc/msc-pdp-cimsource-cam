var currentPdpTablewiewTab = 'tab-data-0'

const setCurrentPdpTableviewTab = (selectedTabId) => {
  currentPdpTablewiewTab = selectedTabId
  resizeFeaturedItemTableCells()
}

const resizeFeaturedItemTableCells = () => {
  const featuredItemTableWidth = document.querySelectorAll('#pdp-tv-current-item')[0]?.getBoundingClientRect()?.width
  const baseTableWidth = document.querySelectorAll(`#${currentPdpTablewiewTab} table:first-child`)[0]?.getBoundingClientRect()?.width
  const elemPdpTableviewFeaturedItemCells = document.querySelectorAll('#pdp-tv-current-item tr:first-child th')
  const selectorForTableRowCells = `#${currentPdpTablewiewTab} table:first-child tr:first-child th`
  const elemPdpTableViewTableRowCells = document.querySelectorAll(selectorForTableRowCells)

  const syncFeaturedItemCellsToPdpTableViewCallsize = () => {
    let featureTable = Array.from(elemPdpTableviewFeaturedItemCells) ?? []
    let baseTable = Array.from(elemPdpTableViewTableRowCells) ?? []
    let baseTableArrayLength = baseTable.length
    let scrollBarWidth = featuredItemTableWidth - baseTableWidth
    for (cell in featureTable) {
      let currentCellWidth = baseTable[cell].getBoundingClientRect()?.width ?? false
      if (currentCellWidth && currentCellWidth > 0) {
        let tableWidthDelta = (cell != baseTableArrayLength - 1) ? 0 : scrollBarWidth
        featureTable[cell].style.width = `${currentCellWidth + tableWidthDelta}px`
      }
    }

  }

  if (featuredItemTableWidth && baseTableWidth) {
    syncFeaturedItemCellsToPdpTableViewCallsize()
  }
}

