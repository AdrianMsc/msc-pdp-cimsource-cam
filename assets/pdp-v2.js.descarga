const streamlinedPdp = {
  specificationsDropdownToggle: () => {
    const dropDownSpec = document.getElementById('specifications-dropdown-button');
    dropDownSpec.classList.toggle('rotate-180');

    const tableSection = document.querySelectorAll('#specifications-table .hc');
    tableSection.forEach(section => {
      section.classList.toggle('hidden');
    });
  },

  calculateItemPrice: (elemId, label = "") => {
    // Get DOM elements
    const quantityErrorElem = getByName(`quantity-input-error${label}`);
    const quantityElem = getByName(`${elemId}${label}`);
    const quantityInputElem = getByName(`pdp-quantity-input${label}`);
    const lengthInputElem = getByName(`length${label}`);
    const totalPriceElem = document.getElementById('totalPriceId');
    const totalPriceStickyNavElem = document.getElementById("totalPriceIdStickyNav") || {};

    // Get values
    const length = getElementValue(lengthInputElem) || 1;
    const quantityInput = getElementValue(quantityInputElem, 1);
    let quantity = quantityElem && quantityElem.length > 0 
      ? getElementValue(quantityElem, 1) 
      : 1;

    quantity = Math.max(quantity, quantityInput);

    if (quantityErrorElem && quantityErrorElem.length > 0) {
      quantityErrorElem[0].innerHTML = '';
    }
    
    const hasLengthInput = lengthInputElem && lengthInputElem.length > 0 && document.getElementById('pdp-input-length');
    if (hasLengthInput) {
      validateInputLength(lengthInputElem, quantity);
    }

    if (totalPriceElem) {
      const totalQuantity = Number(length) * Number(quantity);
      highlightRangePrice(totalQuantity);
      
      const webPriceElem = document.getElementById('webPriceId') || {};
      const matchingPriceItem = priceObject?.priceList?.find(item => 
        item.price && item.fromQuantity <= totalQuantity && item.toQuantity >= totalQuantity
      );

      if (matchingPriceItem) {
        const calculatedTotal = Number(totalQuantity) * Number(matchingPriceItem.price);
        const formattedPrice = '$' + utils.formatNumberWithCommas(calculatedTotal.toFixed(2));
        
        webPriceElem.innerHTML = matchingPriceItem.priceDisplayText || '';
        totalPriceElem.innerHTML = formattedPrice;
        
        if (totalPriceStickyNavElem) {
          totalPriceStickyNavElem.innerHTML = formattedPrice;
        }
      }
    }
  },

  updatePdpInputLength: (label = "") => {
    document.getElementById('pdp-input-length').value = document.getElementById('select-length').value;
    streamlinedPdp.calculateItemPrice('quantity', label);
  },

  incrementQuantity: () => {
    const input = document.getElementById('pdp-quantity');
    const min = parseInt(input.getAttribute('data-min')) || 1;
    const maxLength = parseInt(input.getAttribute('maxlength')) || 5;
    let currentValue = parseInt(input.value);

    let cartErrorMessage = document.getElementById('cart-error-message');
    let qtyError = document.getElementsByClassName("pdp-qty-error")[0];

    if (isNaN(currentValue) || currentValue < 1) {
        input.value = min;
    } else {
        let newValue = currentValue + 1;
        if (newValue.toString().length <= maxLength) {
            input.value = newValue;
           }
          }
          input.dispatchEvent(new Event('keyup'));
          qtyError.style.display =  (qtyError != undefined) ? 'none' : ''; 
          input.classList.remove("errorClass"); 
          cartErrorMessage.style.display =  (cartErrorMessage != undefined) ? 'none' : ''; 
  },

  enforceMinQuantity(input) {
    if (input.value === '' || Number(input.value) < 1) {
       input.value = '';
       }
   },

decrementQuantity: () => {
  const input = document.getElementById('pdp-quantity');
  const min = parseInt(input.getAttribute('data-min')) || 1;

  let currentValue = parseInt(input.value) || min;
  let newValue = currentValue - 1;

  // Ensure the new value doesn't go below the minimum
  if (newValue >= min) {
      input.value = newValue;
      input.dispatchEvent(new Event('keyup')); // Trigger any keyup listeners like calculateItemPrice
  }
},

// Quantity update debounce function for plus/minus buttons
triggerQuantityUpdate() {
  if (!this.quantityUpdateTimer) {
    this.quantityUpdateTimer = null;
  }
  clearTimeout(this.quantityUpdateTimer);
  this.quantityUpdateTimer = setTimeout(() => {
    const input = document.getElementById('pdp-quantity');
    if (input) {
      htmx.trigger(input, 'change');
    }
  }, 500);
}
};

/* WINDOW ONLOAD EVENTS FOR STREAMLINED PDP */

document.addEventListener('DOMContentLoaded', () => {

  document.getElementById('specifications-dropdown-button')?.addEventListener('click', streamlinedPdp.specificationsDropdownToggle);

  setTimeout(() => {
    // Get input elements
    const lengthInput = document.getElementById('pdp-input-length');
    const selectLength = document.getElementById('select-length');
    const quantityInput = document.getElementById('pdp-quantity');

    const setMinimumValue = (element) => {
      if (!element) return;
      const minQty = element.getAttribute('data-min') || 1;
      element.value = minQty;
    };

    setMinimumValue(lengthInput);
    setMinimumValue(selectLength);
    setMinimumValue(quantityInput);

    const isCTLProduct = lengthInput || selectLength;
    const label = isCTLProduct ? '-new' : '';
    
    if (isCTLProduct || quantityInput) {
      calculateItemPrice('quantity', label);
    }
  }, 100);

})

// STREAMLINED PDP
function toggleSpecificationsLink(basePartNumber) {
  const hiddenRows = document.querySelectorAll('.specification-row-hidden');
  const toggleText = document.getElementById('specifications-toggle-text');
  const dropdownBtn = document.getElementById('specifications-dropdown-button');
  const specFeedback = document.getElementById('spec-feedback');
  let isHidden = true;
  hiddenRows.forEach(row => {
    if (!row.classList.contains('hidden')) isHidden = false;
  });
  
  // Calculate scroll position BEFORE collapsing
  let targetScrollPosition = null;
  if (!isHidden) {
    const specTable = document.getElementById('specifications-table');
    if (specTable) {
      const rect = specTable.getBoundingClientRect();
      const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
      targetScrollPosition = rect.top + scrollTop - 200;
    }
  }
  
  if (isHidden) {
    hiddenRows.forEach(row => row.classList.remove('hidden'));
    toggleText.textContent = 'Show less specifications';
    dropdownBtn.classList.remove('rotate-180');
    if (specFeedback) specFeedback.classList.remove('hidden');
  } else {
    hiddenRows.forEach(row => row.classList.add('hidden'));
    toggleText.textContent = 'Show all specifications';
    dropdownBtn.classList.add('rotate-180');
    if (specFeedback) specFeedback.classList.add('hidden');
    
    // Scroll to the specifications table when collapsing
    if (targetScrollPosition !== null) {
      setTimeout(() => {
        window.scrollTo({ top: targetScrollPosition, behavior: 'smooth' });
      }, 100);
    }
  }
  sendLinkEvent({
    event_name: 'pdp click',
    //product_id: [`${basePartNumber}`],
    ui_link_name: 'see all product specifications'
  })
}
function writeReviewLink(basePartNumber) {
   sendLinkEvent({
    event_name: 'pdp write review click',
    product_id: [`${basePartNumber}`],
  })
}

const productScrollPosition = () => {
  const showMoreRowsContainer = f('#alternate-products-widget');
  const showMoreRows = f('.product-compare-show-more')
  let targetScrollPosition = null; 
  if(showMoreRowsContainer) { 
    let isScrollable = true;
    showMoreRows.forEach(row => {
      if (!row.classList.contains('f-hidden')) isScrollable = false;
    });
    const rect = showMoreRowsContainer.getBoundingClientRect();
    const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
    targetScrollPosition = rect.top + scrollTop - 200;

    // Scroll to the alts heading when collapsing
    if (isScrollable && targetScrollPosition !== null) {
      setTimeout(() => {
        window.scrollTo({ top: targetScrollPosition, behavior: 'smooth' });
      }, 100);
    }       
  }
}

  const initializeQuantityInput = () => {
    const quantityInput = document.getElementById('pdp-quantity') || 
                         document.getElementById('pdp-input-quantity') || 
                         document.getElementById('quantity');
  
    if (!quantityInput) return;
    
    const minValue = parseInt(quantityInput.getAttribute('data-minorderquantity') || 
                             quantityInput.getAttribute('data-min') || 
                             quantityInput.getAttribute('min')) || 1;
    
    const currentValue = parseInt(quantityInput.value);
    
    if (!quantityInput.value?.trim() || isNaN(currentValue) || currentValue < minValue) {
      quantityInput.value = minValue;
      quantityInput.dispatchEvent(new Event('change', { bubbles: true }));
    }
  };

// Specifications table toggle for mobile
toggleSpecifications = function(basePartNumber) {
  const tbody = document.querySelector('.specs-tbody');
  const specificationsToggleText = document.getElementById('specifications-toggle-text');
  const specificationsToggleChevron = document.getElementById('specifications-toggle-chevron');
  
  if (!tbody) return;
  
  const isExpanded = tbody.classList.contains('expanded');
  
  if (isExpanded) {
    tbody.classList.remove('expanded');
    if (specificationsToggleText) specificationsToggleText.innerHTML = 'Show All Specifications';
    if (specificationsToggleChevron) specificationsToggleChevron.classList.replace('fa-chevron-up', 'fa-chevron-down');
  } else {
    tbody.classList.add('expanded');
    if (specificationsToggleText) specificationsToggleText.innerHTML = 'Show Less Specifications';
    if (specificationsToggleChevron) specificationsToggleChevron.classList.replace('fa-chevron-down', 'fa-chevron-up');
  }
   sendLinkEvent({
    event_name: 'pdp click',
    product_id: [`${basePartNumber}`],
    ui_link_name: 'product specifications'
  })
};
  

const scrollToAlternatives = () => {
  sendLinkEvent({
    event_name: 'pdp click',
    ui_link_name: 'view alternatives'
  })
  const alternateSection = document.getElementById('alternateContainer');
  if (!alternateSection) return;
  const top = alternateSection.getBoundingClientRect().top + window.pageYOffset - 64;
  window.scrollTo({ top, behavior: 'smooth' });
}

