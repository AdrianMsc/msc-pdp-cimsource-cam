const handlerPDPTVTabClick = () => {
  let elem = Array.from(document.querySelectorAll('.tab'))
  if (Array.isArray(elem)) {
    elem.map(tab => {
      tab.addEventListener('click', event => {
        elem.forEach((tabElement) => {
          tabElement.classList.remove('active')
        })
        tab.classList.add('active')

        let tabDataId = tab.getAttribute('tab-data') ?? false
        let tabContainers = Array.from(document.querySelectorAll('.tab-data'))
        if (tabDataId) {
          let tabData = document.getElementById(tabDataId)
          if (Array.isArray(tabContainers)) {
            tabContainers.forEach((tabContainer) => {
              tabContainer.classList.remove('active')

            })
          }
          tabData.classList.add('active')
          setCurrentPdpTableviewTab(tabDataId)
        }

        sendToggleClickEvent(tab.innerText)
      })
    })
  }
}

