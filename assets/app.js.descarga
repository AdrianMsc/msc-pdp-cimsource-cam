/**
 * Handles response from forget username - "UserName not found." - into the form
 */
function handleForgetUsernameResponse(event)
{
  let xhr = event.detail.xhr;
  if (!xhr || !xhr.responseText) {
    return;
  }
  let response;
  try {
    response = JSON.parse(xhr.responseText);
    console.log(response, 'forget username response handling app.js 2')
  } catch (e) {
    console.error('Invalid JSON response');
    return;
  }
  if(response?.code.includes('40') && response?.message === "UserName not found."){
    let errorContainer = document.getElementById('email-error-container-fu');
    showGenericErrorMessageForAnyFormField('The information you provided does not match our records. Please try again.', errorContainer);
  }
  else if(response?.code === "200 OK" && response?.message === "Email Sent Successully"){
    showSignInForm();
    document.getElementById('request-username-success')?.classList.remove('hidden');
  }
}
  /**
 * Handles response from create account - duplicate intrinsic user - signup drawer - into the form
 */
function handleCreateAccountResponse(event) {
  let xhr = event.detail.xhr;
  if (!xhr || !xhr.responseText) {
    return;
  }
  let response;
  try {
    response = JSON.parse(xhr.responseText)?.appMessage;
  } catch (e) {
    console.error('Invalid JSON response');
    return;
  }
  if (response?.messageType === 'ERROR' && response?.code.includes("200") && response?.message === 'The username already exists.') {
      document.getElementById("duplicate-account-error")?.classList.remove("hidden");
  }
  else if(response?.messageType === 'SUCCESS' && response?.code.includes("200") && response?.message.includes("created successfully")){
    showSignInForm();
  }
}
/**
 * Handles response from intrinsic password reset into the form
 */
  function handleResetPasswordResponse(event) {
    let xhr = event.detail.xhr;
    if (!xhr || !xhr.responseText) {
      return;
    }

    let response;
    try {
      response = JSON.parse(xhr.responseText);
    } catch (e) {
      console.error('Invalid JSON response');
      return;
    }

    let errorContainer = document.getElementById('email-error-container-fp');
    let emailEl = document.getElementById('email1');

    // Clear previous messages
    errorContainer.innerHTML = '';

    // Handle error (401 or unsuccessful)
    if (response?.code.includes ('40')) {
      showGenericErrorMessageForAnyFormField("Invalid or unauthorised user.", errorContainer, emailEl);
      return;
    }

    // Handle success
    if (response?.successful === true && response?.code.includes("200")) {
        document.getElementById("request-password-success")?.classList.remove("hidden");
        document.getElementById("request-password-try")?.classList.add("hidden");
    }
  }

