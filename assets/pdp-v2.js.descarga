const determineFrequentlyViewedTogetherUi = () => {
  let breakpoint = 1680;
  let windowWidth = utils.getWindowWidth();
  let horizontalElem = f('#recommendations-container-frequently-viewed-together-horizontal');
  let verticalElem = f('[data-id="product-recommendations-frequently-viewed-together-vertical"]');

  if (Array.isArray(verticalElem)) verticalElem = verticalElem[0];

  if (windowWidth > breakpoint) {
    if (horizontalElem) horizontalElem.classList.add('f-hidden');
    sendBodyEvent('frequentlyViewedTogetherVertical');
  } else {
    if (verticalElem) verticalElem.classList.add('f-hidden');
    if (horizontalElem) horizontalElem.classList.remove('f-hidden');
    sendBodyEvent('frequentlyViewedTogetherHorizontal');
  }
}

const showOrHideCompliances = () => {
  const containers = document.querySelectorAll('#compliances-container')
  const showHideButtons = document.querySelectorAll('#compliance-show-hide')

  const wasHidden = containers[0]?.classList?.contains('hidden')

  showHideButtons.forEach(showHideButton => {
    showHideButton.innerHTML = wasHidden ? `
      <p class="font-bold">Compliance and Restrictions</p>
      <a class="font-bold hover:underline text-primary">Hide details <i class="fa fa-chevron-up"></i></a>
    ` : `
      <p class="font-bold">Compliance and Restrictions</p>
      <a class="font-bold hover:underline text-primary">View details <i class="fa fa-chevron-down"></i></a>
    `
  })
  containers.forEach(container => container?.classList?.toggle('hidden'))
}
const downloadPDF = (fileName, downloadPdfUrl, configUrl) => {
  const fetchURL = `${configUrl}/global/images/ProductDataSheet/${downloadPdfUrl}.pdf`;
  fetch(fetchURL)
    .then((response) => response.blob())
    .then((blob) => {
      const url = window.URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.style.display = "none";
      a.href = url;
      a.download = fileName;
      document.body.appendChild(a);
      a.click();
      window.URL.revokeObjectURL(url);
    })
    .catch(() => alert("Failed to download file.")); // TODO: Instead of alert, please add proper alert component
}
const fetchPdf = async (url) => {
  const response = await fetch(url);
  return response.arrayBuffer();
}

const loadPdfAndRenderFirstPage = async (pdfUrl2, count) => {
  const pdfData = await fetchPdf(pdfUrl2);

  // Load the PDF using pdf-lib
  const pdfDoc = await PDFLib.PDFDocument.load(pdfData);
  const pdfBytes = await pdfDoc.save();

  // Load the PDF using pdf.js
  const loadingTask = pdfjsLib.getDocument({ data: pdfBytes });
  const pdf = await loadingTask.promise;

  // Get the first page
  const page = await pdf.getPage(1);
  // Prepare canvas using PDF page dimensions
  const viewport = page.getViewport({ scale: 1.5 });
  const canvas = document.getElementById(count + '-pdf-canvas');
  const context = canvas.getContext('2d');
  canvas.height = viewport.height;
  canvas.width = viewport.width;

  // Render the page into the canvas context
  const renderContext = {
    canvasContext: context,
    viewport: viewport,
  };
  await page.render(renderContext).promise;
}
const renderThumnailImageToHtml = (count) => {
  document.getElementById(`${count}-download`).addEventListener('click', () => {
    const canvas = document.getElementById(`${count}-pdf-canvas`);
    const image = canvas.toDataURL('image/png');
    const link = document.createElement('a');
    link.href = image;
    link.download = 'extracted_image.png';
    link.click();
  });
}

document.addEventListener('DOMContentLoaded', () => {
  getStickyNavRevealPoints();
  initZoomImage();
  bindProductPurchaseReviewLinkClick();
  adjustPageDirectAnchor();
  determineFrequentlyViewedTogetherUi();
  hardRestrictionLink();
  tabsActiveToggler();
  handleAltsCompareExpansion();
