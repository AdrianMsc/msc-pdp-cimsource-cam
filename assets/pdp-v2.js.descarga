//
// window onload events
//
document.addEventListener("DOMContentLoaded", () => {
  const modal_container =
    document.getElementById("product-details-tableview-lightbox-stage") ??
    false;
  if (modal_container) {
    // bind modal click if modal present
    modal_container.addEventListener("click", (event) => {
      if (
        event.target.id == "product-details-tableview-lightbox-stage" ||
        event.target.id == "tv-widget-close-button"
      ) {
        closePdpTVLightbox();
      }
    });
    // resize events if modal present
    handlePdpResizeEvents();
  }

  //Handle "Go Back" button click with fallback if no history exists
  const goBackBtn = document.getElementById("goBackBtn");
  if (!goBackBtn) return;
  goBackBtn.addEventListener("click", () => {
    if (window.history.length > 1) {
      window.history.back();
      return;
    }
    const fallbackUrl = goBackBtn.dataset.fallbackUrl || "/";
    window.location.href = fallbackUrl;
  });

  // PowerReview configuration
  const container = document.querySelector("#review-container-box");
  if (container) {
    const dataset = { ...container.dataset }; //using spread operator
    const pwrConfig = {
      api_key: dataset.apiKey,
      locale: dataset.locale,
      merchant_group_id: dataset.merchantGroupId,
      merchant_id: dataset.merchantId,
      merchant_user_email: dataset.userEmail,
      page_id: dataset.pageId,
      review_wrapper_url: dataset.reviewUrl,
      components: {
        Write: "pr-write",
      },
    };

    // Initialize PowerReview rendering function
    window.pwr =
      window.pwr ||
      function () {
        (pwr.q = pwr.q || []).push(arguments);
      };
    // Attempt to render PowerReview component
    if (typeof pwr !== "undefined") {
      pwr("render", pwrConfig);
    } else {
      const fallbackContainer = document.getElementById("pr-write");
      if (fallbackContainer) {
        fallbackContainer.innerHTML = "Unable to load reviews."; //Fallback message if PowerReview fails to load
      }
    }
  }
});

function updateProductPath(path) {
  if (path.includes("/product/") && !path.includes("/product/details/")) {
    return path.replace(/\/product\/(?!details)/, "/product/details/");
  }
  return path;
}

let noChangeCount = 0;
const checkInterval = setInterval(() => {
  if (document.hidden) return;
  const anchorelements = document.querySelectorAll("a.pr-underline");
  const currentHost = window.location.host;
  let updatedCount = 0;
  if (anchorelements.length > 0) {
    anchorelements.forEach((anchorelement) => {
      try {
        const url = new URL(anchorelement.href);
        const originalHref = anchorelement.href;
        url.host = currentHost;
        anchorelement.href = updateProductPath(url.toString());
        if (originalHref !== anchorelement.href) updatedCount++; // Track actual changes
      } catch (error) {
        console.warn("Failed to update PowerReview link:", anchorelement.href);
      }
    });
  }

  // Update thank-you page link to match current host
  const thankYouLink = document.querySelectorAll(".thank-you-page a[href]")[0]
    ?.baseURI;

  if (thankYouLink === null) return;
  const pageHost = window.location.host;
  const thankYouLinkElement = document.querySelectorAll(".thank-you-page a")[1];
  if (!thankYouLinkElement?.host) return;

  try {
    const url = new URL(thankYouLinkElement.href);
    const originalHref = thankYouLinkElement.href;
    url.host = pageHost;
    thankYouLinkElement.href = updateProductPath(url.toString());

    if (originalHref !== thankYouLinkElement.href) {
      updatedCount++;
    }
  } catch (error) {
    console.warn("Failed to update thank you link:", thankYouLinkElement.href);
  }
}, 1000);

window.addEventListener("beforeunload", () => {
  if (updatedCount === 0) {
    noChangeCount++;
    if (noChangeCount >= 10) {
      clearInterval(checkInterval);
    }
  } else {
    noChangeCount = 0; // Reset counter when changes occur
  }
});



