let stickyHeight = 0;

const getStickyNavHeight = () => {
  let minimumHeight = 215;
  stickyHeight = f('#product-sticky').getBoundingClientRect().height;
  return Math.max(minimumHeight, stickyHeight);
};

const getStickyNavRevealPoints = () => {
  const allNecessaryElementsExist = (elementArray) => {
    if (!elementArray || !Array.isArray(elementArray)) return false;
    for (elem in elementArray) {
      if (!elementArray[elem]) return false;
    }
    return true;
  };

  // necessary elements

  //checks the loaded pdp is non web sellable and switching targets
  let addToCartButton = f('#add-to-cart-button');
  if (addToCartButton === null) {
    addToCartButton = f(".error-msg-container")[0];
  }
  const specificationsNavAnchor = f('#specifications-nav-anchor');
  const sticky = f('#product-sticky');
  const stickyDetails = f('#product-sticky-details');

  if (allNecessaryElementsExist([addToCartButton, specificationsNavAnchor, sticky, stickyDetails])) {
    // triggers
    const addToCartBoxY = addToCartButton.getBoundingClientRect().top + window.scrollY;

    const toggleStickyDetails = () => {
      if (window.scrollY >= addToCartBoxY) {
        if (!utils.isVisible(stickyDetails)) {
          stickyDetails.classList.remove('f-hidden');
          getStickyNavHeight();
          getStickyNavRevealPoints();
        }
      } else {
        if (utils.isVisible(stickyDetails)) {
          stickyDetails.classList.add('f-hidden');
          getStickyNavHeight();
        }
      }
    };

    const handlePageScroll = () => {
      window.addEventListener('scroll', () => {
        toggleStickyDetails();
      });
    };

    toggleStickyDetails();
    handlePageScroll();
  }
};

const adjustPageDirectAnchor = () => {
  let urlAnchor = getAnchorFromUrl();
  if (urlAnchor) {
    scrollToAnchor(urlAnchor);
  }
};

const sendCustomBundleAnalytics = (event) => {
  if(event.detail.xhr.responseURL.includes('/product/details/custom-bundles')) {
  sendLinkEvent({
    event_name: 'pdp click',
    ui_link_name: 'bundle and save'
  })
}
};

const sendBundleAddToCartAnalytics = (bundleId, cardItems) => {
  document.querySelector('body').dispatchEvent(new Event('addCartEvent', { bubbles: true }));
  const productIds = [];
  const descriptions = [];
  const listPrices = [];
  const webLowestPrices = [];
  const quantities = [];
  const ratings = [];
  const reviews = [];
  const bundleIdArr = [];

  if (cardItems && Array.isArray(cardItems)) {
    cardItems.forEach((part, index) => {
      productIds.push(part?.basePartNumber);
      descriptions.push(part?.shortDescription);
      listPrices.push(String(part?.orderingInfo?.price || ''));
      if (index === 0) {
        webLowestPrices.push(String(part?.orderingInfo?.webLowestPrice || ''));
      } else {
        webLowestPrices.push(String(part?.alternatePartMatch?.promoPrice || ''));
      }
      quantities.push(String(part?.minQuantity || 1));
      ratings.push(String(part?.rating?.totalRatings || 0));
      reviews.push(String(part?.rating?.averageRating || 0));
      bundleIdArr.push(bundleId);
    });
  }

  sendLinkEvent({
    event_name: 'cart add',
    cart_add_location: 'bundle widget',
    product_id: productIds,
    bundle_id: bundleIdArr,
    product_name: descriptions,
    product_list_price: listPrices,
    product_price: webLowestPrices,
    product_quantity: quantities,
    product_rating: ratings,
    product_reviews: reviews,
    widget_position: '',
    widget_type: ''
  });
};

const getAnchorFromUrl = () => {
  let url = window.location.href;
  if (utils.stringContains('#')) return `#${url.split('#')[1]}`;
  else return false;
};

const bindProductPurchaseReviewLinkClick = () => {
  const reviewLinks = f('.product-details-purchase-reviews-link');
  reviewLinks.forEach((elem) => {
    elem.addEventListener('click', (e) => {
      e.preventDefault();
      let anchorLink = e.target.getAttribute('href');
      scrollToAnchor(anchorLink);
    });
  });
};

const scrollToAnchor = (anchorLink) => {
  let scrollToElement = f(`a[name='${anchorLink.slice(1)}']`)[0];
  let scrollToPosition = scrollToElement?.getBoundingClientRect().top;
  if (scrollToPosition) {
    scrollWindow(scrollToPosition + window.scrollY - getStickyNavHeight(), 0);
  }
  //window.history.replaceState({}, document.title, `${url}${anchorLink}`)
};

const toggleFeaturesBenefits = (elemId) => {
  let fbElem = f(elemId);
  if (fbElem) {
    let lessElem = f(elemId + '-less');
    let moreElem = f(elemId + '-more');
    if (fbElem.classList.contains('clampAfterThird')) {
      fbElem.classList.remove('clampAfterThird');
      if (lessElem) {
        lessElem.classList.remove('hidden');
      }
      if (moreElem) {
        moreElem.classList.add('hidden');
      }
    } else {
      fbElem.classList.add('clampAfterThird');
      if (lessElem) {
        lessElem.classList.add('hidden');
      }
      if (moreElem) {
        moreElem.classList.remove('hidden');
      }
    }
  }
};

const getByName = (elementName) => {
  return document.getElementsByName(elementName);
};

const getElementValue = (nodeList, defaultValue) => {
  return nodeList != undefined && nodeList.length > 0 ? nodeList[0].value : defaultValue;
};

const calculateItemInputPrice = (elemId, label = "") => {
  let quantityElem = getByName(`${elemId}${label}`);
  let quantityInputElem = getByName(`quantity${label}`);
  let quantityErrorElem = getByName(`quantity-input-error${label}`);
  let minimumOrderQuantity = priceObject?.minimumOrderQuantity || 1;

  if (quantityElem != undefined && quantityInputElem != undefined) {
    let quantity = getElementValue(quantityElem, 1);
    let quantityInput = getElementValue(quantityInputElem, 1);
    let cartErrorMessage = document.getElementById('cart-error-message');
    if (Number(quantityInput) > 0 && (Number(quantityInput) % Number(minimumOrderQuantity) == 0)) {
      if (quantityErrorElem != undefined) {
        quantityErrorElem[0].innerHTML = '';
      }
      if (quantityElem[0] != undefined) {
        quantityElem[0].value = quantityInput;
      }
      quantityElem[0].classList.remove('errorClass');
      quantityInputElem[0].classList.remove('errorClass');
      if (cartErrorMessage != undefined) {
        cartErrorMessage.style.display = 'none';
      }
      calculateItemPrice(elemId, label);
    } else if (Number(quantityInput) % Number(minimumOrderQuantity) != 0) {
      quantityElem[0].classList.add('errorClass');
      quantityErrorElem[0].innerHTML = `Quantity must be in multiples of ${minimumOrderQuantity}`;
    } else {
      quantityElem[0].classList.add('errorClass');
      quantityErrorElem[0].innerHTML = 'A specified quantity is required.';
    }
    highlightRangePrice(quantity);
  }
};

const preventNnumericRange = (event) => {
  if (event.key == 'Backspace' || event.key == 'Delete' || event.key == 'ArrowLeft' || event.key == 'ArrowRight') return;
  const value = Number(event.target.value + event.key);
  if (!value || (value <= 0 || value > 99999)) {
    event.preventDefault();
  }
}

const highlightRangePrice = (quantity) => {
  const list = document.getElementsByClassName('quantity-range-price');
  [...list]?.forEach((each) => {
    const fromQuantity = Number(each.getAttribute('from'));
    const toQuantity = Number(each.getAttribute('to'));
    if (fromQuantity <= Number(quantity) && Number(quantity) <= toQuantity) {
      each.classList.add('font-bold');
    } else {
      each.classList.remove('font-bold');
    }
  });
};

const preventNonNumericInput = (event) => {
  if (!(event.keyCode === 8 || (event.key >= 0 && event.key <= 9) || (event.keyCode >= 37 && event.keyCode <= 40))) {
    event.preventDefault();
  }
}

const preventWheel = (event) => {
  event.target.blur();
};

const updatePdpInputLength = (label = "") => {
  document.getElementById('pdp-input-length').value = document.getElementById('select-length').value;
  calculateItemPrice('quantity', label);
};

const showElementClass = (className) => {
  const ele = document.getElementsByClassName(className)[0]
  if (ele) {
    ele.style.display = 'block'
  }
}
const hideElementClass = (className) => {
  const ele = document.getElementsByClassName(className)[0]
  if (ele) {
    ele.style.display = 'none'
  }
}
const validateInputLength = (lengthInputElem, quantityValue = '') => {
  let minimumOrderQuantity = priceObject?.minimumOrderQuantity || 1;
  let lengthValue = getElementValue(lengthInputElem);
  
  if (lengthValue == '' || lengthValue <= 0 || isNaN(lengthValue)) {

    lengthInputElem[0]?.classList?.add('errorClass');
    document.getElementById("cart-error-message").style.display = "block";
    showElementClass('pdp-length-error')
    hideElementClass('pdp-length-multiple-error')
  } else if (Number(lengthValue) % Number(minimumOrderQuantity) != 0) {

    lengthInputElem[0]?.classList.add('errorClass');
    document.getElementById("cart-error-message").style.display = "block";
    showElementClass('pdp-length-multiple-error')
    hideElementClass('pdp-length-error')
  } else {
    hideElementClass('pdp-length-error')
    hideElementClass('pdp-length-multiple-error')
    lengthInputElem[0]?.classList.remove('errorClass');
    document.getElementById("cart-error-message").style.display = "none";
  }
};

const calculateItemPrice = (elemId, label = "") => {
  let quantityErrorElem = getByName(`quantity-input-error${label}`);
  let quantityElem = getByName(`${elemId}${label}`);
  let quantityInputElem = getByName(`pdp-quantity-input${label}`);
  let lengthInputElem = getByName(`length${label}`);

  let quantity = undefined;
  let price = undefined;
  let length = getElementValue(lengthInputElem) || 1;
  let quantityInput = getElementValue(quantityInputElem, 1);

  let totalPriceElem = document.getElementById('totalPriceId');
  let totalPriceStickyNavElem = document.getElementById("totalPriceIdStickyNav") || {};

  if (quantityErrorElem && quantityErrorElem.length > 0) {
    quantityErrorElem[0].innerHTML = '';
  }
  
  if (quantityElem && quantityElem.length > 0) {
    quantity = getElementValue(quantityElem, 1);
  }
  
  if (quantityInput > quantity) {
    quantity = quantityInput;
  }
  
  if (lengthInputElem && lengthInputElem.length > 0 && (document.getElementById('pdp-input-length') || document.getElementById('select-length')))  {
    validateInputLength(lengthInputElem, quantity);
  }
  
  if (totalPriceElem) {
    let totalQuantity = Number(length) * Number(quantity);
    highlightRangePrice(totalQuantity);
    let webPriceElem = document.getElementById('webPriceId') || {};
    priceObject?.priceList?.forEach(item => {
      if (item.price && item.fromQuantity <= totalQuantity && item.toQuantity >= totalQuantity) {
        price = item.price;
        webPriceElem.innerHTML = item.priceDisplayText || '';
        totalPriceElem.innerHTML = '$' + utils.formatNumberWithCommas(Number(totalQuantity * Number(price)).toFixed(2));
        if (totalPriceStickyNavElem) {
          totalPriceStickyNavElem.innerHTML = '$' + utils.formatNumberWithCommas(Number(totalQuantity * Number(price)).toFixed(2));
        }
      }
    });
  }
};

const formatPriceDisplayText = (partWebLowestPriceDisplayText) => {
  let formattedDisplayTextForRecommendations = partWebLowestPriceDisplayText;
  let partWebLowestPriceDisplayTextSplit = partWebLowestPriceDisplayText.split(' ');
  if (partWebLowestPriceDisplayTextSplit[partWebLowestPriceDisplayTextSplit.length - 1]) {
    const metric = partWebLowestPriceDisplayTextSplit[partWebLowestPriceDisplayTextSplit.length - 1]
    // This is probably a bug on production but we have to mimic prod functionality for now
    const redundantText = Number(metric) ? partWebLowestPriceDisplayTextSplit[partWebLowestPriceDisplayTextSplit.length - 2] : ""
    return `${partWebLowestPriceDisplayTextSplit[0]}<span class="text-sm leading-14" style="font-weight: normal"> / ${redundantText} ${partWebLowestPriceDisplayTextSplit[partWebLowestPriceDisplayTextSplit.length - 1]}</span>`;
  } else {
    return formattedDisplayTextForRecommendations;
  }
};

