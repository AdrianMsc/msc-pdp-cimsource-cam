const generateErrorAndInvalidZip = (eventResponse) => {
  const zipResponseFlag = JSON.parse(eventResponse)
  if(zipResponseFlag.isZipInvalid) {
    var zipcodeElm = f('#add-zip-code');
    if (zipcodeElm) {
      toggleZipInputVisibility();
      zipcodeElm.setCustomValidity('Invalid Zip Code');
    }
  } else {
    var iconElm = document.querySelector("#delivery-date-container i");
    var spanElm = document.querySelector("#delivery-date-container span");
    if (iconElm && spanElm) {
      iconElm.setAttribute("class", "fas fa-exclamation-triangle tw-text-warning-orange m-2");
      spanElm.textContent = "We cannot determine the delivery date with this zipcode";
      document.querySelector("#delivery-date-container")?.classList?.remove("hidden");
    }
  }
}

