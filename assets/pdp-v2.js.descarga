  setTimeout(initializeQuantityInput, 100);



const cadContainer = document.querySelector('[data-init-cad-lightbox]');
    if (!cadContainer) return;

    const viewerContainerId = 'cds-cad-viewer-container-lightbox';
    const iconContainerId = 'cds-icon-container-lightbox';

    const maxRetries = 4;
    const retryDelay = 400;
    let retryCount = 0;

    const loadCadViewer = () => {
        if (typeof cds === 'object') {
            cds.cadViewer.dispose();
            cds.CADRequester.setContainerElementId(cadContainer.id);
            cds.CADRequester.webglViewerElementId = viewerContainerId;
            cds.CADRequester.webglIconsElementId = iconContainerId;
            cds.CADRequester.load();
        } else if (retryCount < maxRetries) {
            retryCount++;
            setTimeout(loadCadViewer, retryDelay);
        }
    };

    loadCadViewer();

    // Bind icon actions
    cadContainer.querySelectorAll('[data-action]').forEach(img => {
        img.addEventListener('click', () => {
            const action = img.getAttribute('data-action');
            switch (action) {
                case 'MODE_SHADED':
                    cds.cadViewer.setRenderMode(cds.cadViewer.MODE_SHADED);
                    break;
                case 'MODE_TRANSPARENT':
                    cds.cadViewer.setRenderMode(cds.cadViewer.MODE_TRANSPARENT);
                    break;
                case 'VIEW_ISOMETRIC':
                    cds.cadViewer.setOrientation(cds.cadViewer.VIEW_ISOMETRIC);
                    break;
                case 'VIEW_TOP':
                    cds.cadViewer.setOrientation(cds.cadViewer.VIEW_TOP);
                    break;
                case 'VIEW_LEFT':
                    cds.cadViewer.setOrientation(cds.cadViewer.VIEW_LEFT);
                    break;
                case 'VIEW_BOTTOM':
                    cds.cadViewer.setOrientation(cds.cadViewer.VIEW_BOTTOM);
                    break;
                case 'VIEW_RIGHT':
                    cds.cadViewer.setOrientation(cds.cadViewer.VIEW_RIGHT);
                    break;
                case 'FULLSCREEN':
                    cds.cadViewer.setFullScreen();
                    break;
                case 'TOGGLE_GRID':
                    cds.cadViewer.toggleBaseGrid();
                    break;
                case 'TOGGLE_SHADOW':
                    cds.cadViewer.toggleShadowinViewer();
                    break;
            }
        });
    });


const cadFrame = document.getElementById("product-cad-frame");
    if (!cadFrame) return;

    const domain = cadFrame.dataset.domain;
    const product = cadFrame.dataset.product;
    const maxRetriess = parseInt(cadFrame.dataset.maxRetriess || "4");
    const retryTimer = parseInt(cadFrame.dataset.retryTimer || "400");
    let retryCounter = 0;

    function loadCad() {
        if (typeof cds === 'object') {
            cds.CADRequester.setDomain(domain);
            cds.CADRequester.setProduct(product);
            cds.CADRequester.setContainerElementId("cds-cad-container");
            cds.CADRequester.setFormatSelectElementId("cds-cad-download-formats");
            cds.CADRequester.setDownloadButtonElementId("cds-cad-download-button");
            cds.CADRequester.setView2DButtonElementId("cds-cad-view-2D-button");
            cds.CADRequester.webglViewerElementId = "cds-cad-viewer-container";
            cds.CADRequester.webglIconsElementId = "cds-icon-container";
            cds.CADRequester.load();

            document.getElementById("cds-icon-container").classList.remove("hidden");

            attachIconHandlers();
        } else {
            if (retryCounter < maxRetriess) {
                retryCounter++;
                setTimeout(loadCad, retryTimer);
            }
        }
    }

    function attachIconHandlers() {
        const icons = document.querySelectorAll("#cds-icon-container img");
        icons.forEach(icon => {
            icon.addEventListener("click", () => {
                const mode = icon.dataset.mode;
                const orientation = icon.dataset.orientation;
                const action = icon.dataset.action;

                if (mode) cds.cadViewer.setRenderMode(cds.cadViewer[mode]);
                if (orientation) cds.cadViewer.setOrientation(cds.cadViewer[orientation]);
                if (action === "fullscreen") cds.cadViewer.setFullScreen();
                if (action === "grid") cds.cadViewer.toggleBaseGrid();
                if (action === "shadow") cds.cadViewer.toggleShadowinViewer();
            });
        });
    }

    loadCad();
});

function handleButtonClick(event) {
  const button = document.getElementById('pdp-tv-button');
  const buttonText = document.getElementById('button-text');
  const spinner = document.getElementById('spinner');

  button.disabled = true;
  buttonText.style.display = 'none';
  spinner.style.display = 'inline-block';
}

function handleAfterSwap(event) {
  const button = document.getElementById('pdp-tv-button');
  const buttonText = document.getElementById('button-text');
  const spinner = document.getElementById('spinner');

  button.disabled = false;
  buttonText.style.display = 'inline-block';
  spinner.style.display = 'none';
}

