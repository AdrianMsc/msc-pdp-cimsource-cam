const handleGetMyList = () =>  {
  const isGetMylist = f("#addItemsToList");
  if(!isGetMylist) return

  const myListElem = f("#myList");
  let getListID = myListElem.value;
  const selectedIndex = myListElem.selectedIndex;
  const option = myListElem[selectedIndex];
  const listIdValue = getListID === "Create" ? "" : option.getAttribute("data-id");
  f("#hiddenListID").setAttribute("value",listIdValue);

  if(getListID === "Create"){
    f('#create_new').classList.remove('hidden');
    if(f('#list_name')) {
    f('#list_name').value = '';
  }
  }else{
    f('#create_new').classList.add('hidden');
    if(f('#list_name')) {
    f('#list_name').value = option?.innerHTML || '';
  }
  }
}  
