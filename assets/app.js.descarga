    modal.remove(); 
} 

function executeVendedItemInitialScripts() {
    const vendedItemScriptTag = document.getElementById("vended-item-data-script")
    if (!vendedItemScriptTag) {
        return
    }

    const locationDropdown = document.getElementById("vended-item-location-dropdown");
    const machineDropdown = document.getElementById("vended-item-machine-dropdown");
    const syncDateElement = document.getElementById("vended-item-sync-date");
    let selectedLocation = null;

    const setQuantityValues = (onHand = '', minQty= '', maxQty= '') => {
        document.getElementById("vended-item-qtyOnHand").innerHTML = onHand;
        document.getElementById("vended-item-minimumQty").innerHTML = minQty;
        document.getElementById("vended-item-maximumQty").innerHTML = maxQty;
    }

    const syncDate = (date) => {
        const lastDataSyncDate = date ? new Date(date) : null
        const options = { year: "numeric", month: "long", day: "numeric" }
        syncDateElement.textContent =  !lastDataSyncDate ? '' : `Data as of ${lastDataSyncDate?.toLocaleDateString("en-US", options)}`
    }

    const selectMachineOptionByDefault = (dropdown, option) => {
      const {vmid, locationNote, qtyOnHand, minimumQty, maximumQty, lastDataSyncDate} = option || {};
      dropdown.innerHTML = `<option value="${vmid}" selected>${locationNote}</option>`;
      setQuantityValues(qtyOnHand, minimumQty, maximumQty);
      syncDate(lastDataSyncDate);
    }

    const handleLocationChange = (event, locations) => {
        const selectedLocationId = event.target.value;
        selectedLocation = locations.find(location => location?.locationId === selectedLocationId);
        const vmDetails = selectedLocation?.vmDetails;
        if(vmDetails?.length === 1) {
          selectMachineOptionByDefault(machineDropdown, vmDetails[0]);
          return;
        }
        machineDropdown.innerHTML = `<option value="" disabled selected>Select a machine</option>`;
        vmDetails.forEach(vm => {
            machineDropdown.innerHTML += `<option value="${vm?.vmid}">${vm?.locationNote}</option>`;
        });
        setQuantityValues(); //reset quantity values when location changes until a machine is selected
        syncDate(); //reset sync date when location changes until a machine is selected
    }

    const handleVendingMachineChange = (event) => {
        const selectedMachineId = event.target.value;
        const machines = selectedLocation?.vmDetails || [];
        const selectedMachine = machines.find(machine => machine?.vmid === selectedMachineId);
        setQuantityValues(selectedMachine?.qtyOnHand, selectedMachine?.minimumQty, selectedMachine?.maximumQty);
        syncDate(selectedMachine?.lastDataSyncDate);
    }

    try {
        const { locations } = JSON.parse(vendedItemScriptTag.textContent)
        locationDropdown.addEventListener('change', (event) => handleLocationChange(event, locations))
        machineDropdown.addEventListener('change', (event) => handleVendingMachineChange(event))
        
        // If only one location, select it by default
        if (locations?.length === 1) {
            const syntheticEvent = {
                target: {
                    value: locations[0]?.locationId
                }
            };
            locationDropdown.value = locations[0]?.locationId;
            handleLocationChange(syntheticEvent, locations);
        }
    } catch (err) {
        console.error("Failed to parse JSON-LD", err)
    }
}
