/**
 * Function to handle the email input validation on input
 * @param {*} input 
 */
function validateEmailInput(input) {
  const errorMsg = document.getElementById('signup-email_errorMsg');
  const value = input.value.trim();
  const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  if (!value) {
    if(errorMsg) errorMsg.textContent = 'Email is required.';
    input.classList.add('input-error');
  } else if (!emailPattern.test(value)) {
    if(errorMsg) errorMsg.textContent = 'Please enter a valid email address.';
    input.classList.add('input-error');
  } else {
    if(errorMsg) errorMsg.textContent = '';
    input.classList.remove('input-error');
  }
}

/**
 * Updates button state based on validation
 * Similar to setLoadingState/removeLoadingState from app.js but for validation
 * @param {string} buttonId - The ID of the button to update
 * @param {boolean} isValid - Whether the form is valid
 */
function updateButtonState(buttonId, isValid) {
  try {
    const button = document.getElementById(buttonId);
    if (!button) return;
    
    if (isValid) {
      button.disabled = false;
      button.classList.remove('tw-opacity-50', 'tw-cursor-not-allowed');
      button.classList.add('hover:tw-bg-primary-dark');
    } else {
      button.disabled = true;
      button.classList.add('tw-opacity-50', 'tw-cursor-not-allowed');
      button.classList.remove('hover:tw-bg-primary-dark');
    }
  } catch (e) {
    console.error('updateButtonState error:', e);
  }
}

/**
 * Updates requirement icon to show check or circle
 * @param {string} iconId - The ID of the icon element
 * @param {boolean} isValid - Whether the requirement is met
 */
function updateRequirementIcon(iconId, isValid) {
  try {
    const icon = document.getElementById(iconId);
    if (!icon) return;
    
    if (isValid) {
      icon.classList.remove('fa-circle', 'text-monochrome-light', 'tw-text-monochrome-light');
      icon.classList.add('fa-check-circle', 'text-primary', 'tw-text-primary');
    } else {
      icon.classList.remove('fa-check-circle', 'text-primary', 'tw-text-primary');
      icon.classList.add('fa-circle', 'text-monochrome-light', 'tw-text-monochrome-light');
    }
  } catch (e) {
    console.error('updateRequirementIcon error:', e);
  }
}
/**
 * Shows password requirements section
 * Removes hidden class when input is focused
 */
function showPasswordRequirements() {
  try {
    const requirements = document.getElementById('intrinsicPasswordRequirements');
    if (requirements) {
      requirements.classList.remove('hidden');
    }
  } catch (e) {
    console.error('intrinsicPasswordRequirements error:', e);
  }
}
/**
 * Validates password requirements in real-time
 * Updates checkmark icons based on password criteria
 */
function validateCredentialRequirements() {
  try {
    const credential = document.getElementById('credential')?.value || '';
    const validation = getPasswordValidationState(credential);
    
    updateRequirementIcon('req-letter', validation.hasLetter);
    updateRequirementIcon('req-number', validation.hasNumber);
    updateRequirementIcon('req-length', validation.hasMinLength);
    updateRequirementIcon('req-consecutive', validation.hasValidConsecutive);
    
  } catch (e) {
    console.error('validateCredentialRequirements error:', e);
  }
}
/**
 * Helper function to check password validation rules
 * @param {string} credential - The password to validate
 * @returns {Object} Validation state with properties: isValid, hasMinLength, hasNumber, hasLetter, hasValidConsecutive
 */
function getPasswordValidationState(credential) {
  const hasMinLength = credential.length >= 8;
  const hasNumber = /\d/.test(credential);
  const hasLetter = /[a-zA-Z]/.test(credential);
  const hasValidConsecutive = !/(.)\1{3,}/.test(credential);
  
  return {
    isValid: hasMinLength && hasNumber && hasLetter && hasValidConsecutive,
    hasMinLength,
    hasNumber,
    hasLetter,
    hasValidConsecutive
  };
}
/**
 * Validates current password field on blur
 * Shows required field error if empty
 * @returns {boolean} - True if validation passes, false otherwise
 */
function validateCurrentPassword(isBlur = false) {
  try {
    const credential = document.getElementById('credential')?.value || '';
    const repeatCredential = document.getElementById('repeatCredential')?.value || '';
    const email = document.getElementById('email')?.value?.trim() || '';
    // If valid, clear error and validate overall state
    clearFieldError('credential');

    // If empty, show required error on blur, otherwise just disable button
    if (credential === '') {
      if (isBlur) {
        showAccountSettingsFieldError('credential', 'Password is a required field');
        updateButtonState('create-account-button', false);
        return false;
      }
    }
    if(email && credential && email == credential){
      showAccountSettingsFieldError('credential', "Password cannot be the same as the username or email address.");
      updateButtonState('create-account-button', false);
      return false;
    }

    const validation = getPasswordValidationState(credential);
    
    // Show appropriate error message for first failing rule
    if (!validation.hasMinLength) {
      showAccountSettingsFieldError('credential', 'Password must be at least 8 characters');
      updateButtonState('create-account-button', false);
      return false;
    }
    
    if (!validation.hasNumber) {
      showAccountSettingsFieldError('credential', 'Password must have at least one number');
      updateButtonState('create-account-button', false);
      return false;
    }
    
    if (!validation.hasLetter) {
      showAccountSettingsFieldError('credential', 'Password must have at least one letter');
      updateButtonState('create-account-button', false);
      return false;
    }
    
    if (!validation.hasValidConsecutive) {
      showAccountSettingsFieldError('credential', 'Password must not have more than 3 of the same consecutive characters');
      updateButtonState('create-account-button', false);
      return false;
    }
    
    // If we reach here, password is valid - check overall form state
    clearFieldError('credential');
    
    // Validate confirm password if it has a value
    if (repeatCredential !== '') {
      validateConfirmPassword();
    }
    return true;
  } catch (e) {
    console.error('validateCurrentPassword error:', e);
    return false;
  }
}
/**
 * Handles new password input blur event
 * Validates new password and adds oninput validation after first blur
 */
function handleNewPasswordBlur() {
  try {
    // Validate the new password field
    validateCurrentPassword(true);
    
    // Add oninput validation after first blur
    const newPasswordField = document.getElementById('credential');
    if (newPasswordField && !newPasswordField.dataset.oninputAdded) {
      // Keep validateCredentialRequirements and add validateCurrentPassword
      newPasswordField.setAttribute('oninput', 'validateCredentialRequirements(); validateCurrentPassword();');
      newPasswordField.dataset.oninputAdded = 'true';
    }
  } catch (e) {
    console.error('handleNewPasswordBlur error:', e);
  }
}
function validateCreateAccountBeforeSubmit() {
  try {
    const currentPasswordValid = validateCurrentPassword(true);
    const confirmPasswordValid = validateConfirmPassword();
    const newEmail = validateEmail();
    const confirmEmail = validateConfirmEmail()
    
    return currentPasswordValid &&  confirmPasswordValid && newEmail && confirmEmail;
  } catch (e) {
    console.error('validateCreateAccountBeforeSubmit error:', e);
    return false;
  }
}

/**
 * Form submission handler for signup form
 * @param {*} event 
 * @returns 
 */
function handleSignupForm(event) {
  const form = event.target;
  event.preventDefault();
  // Get the email value
  const emailInput = form.querySelector('input[type="email"], input[name="email"], input[id*="email"]');
  const emailAddress = emailInput ? emailInput.value.trim() : "";

  // Decode the data-fieldset attribute (contains the Salesforce config)
  const fieldsetData = form.getAttribute("data-fieldset");
  let config = {};
  try {
    config = JSON.parse(decodeURIComponent(fieldsetData || "%7B%7D"));
  } catch (e) {
    showSignupFormError(form, "An error occurred. Please try again later.");
    return;
  }

  // Extract Salesforce endpoint info
  const { endpointUrl, oid, recordType, leadSource } = config;
  if (!endpointUrl || !oid || !recordType || !leadSource) {
    showSignupFormError(form, "An error occurred. Please try again later. (Missing configuration)");
    return;
  }

  // Build the Salesforce API endpoint URL
  const apiEndpoint = `${endpointUrl}&oid=${oid}&recordType=${recordType}&email=${encodeURIComponent(emailAddress)}&lead_source=${encodeURIComponent(leadSource)}`;
  const requestOptions = {
    method: "POST",
    mode: "no-cors"
  };

  fetch(apiEndpoint, requestOptions)
    .then((response) => {
      // Show thank you message and hide the form
      form.style.display = "none";
      let thankYouMsg = document.createElement("div");
      thankYouMsg.className = "signup-thankyou-message";
      thankYouMsg.innerHTML = `<div class='text-green-700 text-lg font-semibold text-center py-8'>Thank You, Your email is subscribed now.</div>`;
      form.parentNode.insertBefore(thankYouMsg, form.nextSibling);
    })
    .catch((e) => {
      if (loading) loading.classList.add("hidden");
      showSignupFormError(form, "An error occurred. Please try again later.");
      return e;
    });
}

/**
 * Function to show error message below the signup form
 * @param {*} form 
 * @param {*} message 
 */
function showSignupFormError(form, message) {
  let errorMsg = form.querySelector('#signup-email_errorMsg');
  if (!errorMsg) {
    errorMsg = document.createElement('div');
    errorMsg.className = 'signup-error-message text-red-600 text-sm mx-8 mb-4';
    form.appendChild(errorMsg);
  }
  errorMsg.textContent = message;
}

function getHxValsForAddToList(productId, isQuantity) {
  function getElementValue(id) {
    return document.getElementById(id)?.value;
  }

  const productIdElement =  document.getElementById(`${productId}-quantity`);
  const quantityValue = getElementValue('pdp-quantity') || getElementValue('pdp-input-quantity') || getElementValue('quantity') ||
  (Number(productIdElement?.value) ? productIdElement?.value : productIdElement?.dataset?.min);

  const cutToLength = getElementValue('pdp-input-length') || getElementValue(`${productId}-length`) || '';
  return isQuantity ? quantityValue : cutToLength;
}

const removeVendedItemModal = () => { 
    const overlay = document.getElementById('vended-item-overlay'); 
    const modal = document.getElementById('vended-item-modal'); 
