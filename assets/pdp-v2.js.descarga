const loadMobileAltsContainers = () => {
  let isExpanded = false;
  const mobileToggleId = f('#mobileToggleComparison');
  if(!mobileToggleId) return;

  mobileToggleId.addEventListener('click', ()=> {
    sendLinkEvent({
        event_name: 'pdp click',
        ui_link_name: 'compare alternate products',
    });
    const isAlternateExpanded = f('#alternate-expanded-mode');
    const isAlternateCollapsed = f('#alternate-collapsed-mode');
    isAlternateExpanded.style.display = 'none'; // Default hide the expanded view

    if(isExpanded) {
      f('#alternate-compare-toggle').classList.add('fa-plus');
      f('#alternate-compare-toggle').classList.remove('fa-minus');
      isAlternateExpanded.style.display = 'none';
      isAlternateCollapsed.style.display = 'block';
      isExpanded = false;
    } else {
      f('#alternate-compare-toggle').classList.remove('fa-plus');
      f('#alternate-compare-toggle').classList.add('fa-minus');
      isAlternateExpanded.style.display = 'block';
      isAlternateCollapsed.style.display = 'none';
      isExpanded = true;
    }
  })

}

function toggleSpecifications(basePartNumber) {
  const hiddenSpecs = document.getElementById('spec-preview-hidden');
  const specFeedback = document.getElementById('spec-feedback')
  const isHidden = hiddenSpecs?.classList.contains('hidden');
  const specificationsToggleText = document.getElementById('specifications-toggle-text');
  const specificationsToggleChevron = document.getElementById('specifications-toggle-chevron');

  if (isHidden) {
    specificationsToggleText.innerHTML = 'Show less product specifications';
    specificationsToggleChevron.classList.replace('fa-chevron-down', 'fa-chevron-up');
  } else {
    specificationsToggleText.innerHTML = 'See all product specifications';
    specificationsToggleChevron.classList.replace('fa-chevron-up', 'fa-chevron-down');
  }
  sendLinkEvent({
    event_name: 'pdp click',
    product_id: [`${basePartNumber}`],
    ui_link_name: 'product specifications'
  })
  hiddenSpecs.classList.toggle('hidden');
  specFeedback.classList.toggle('hidden')
}

