function validateConfirmResetLink() {
  const input = document.getElementById('passlink');
  const errorEl = document.getElementById('link-error-container');

  if (errorEl) {
    errorEl.innerHTML = "";
  }

  let url;

  try {
    url = new URL(input.value.trim());
  } catch {
    showGenericErrorMessageForAnyFormField("Invalid URL format.", errorEl, input);
    return;
  }

  const key = url.searchParams.get("key");
  const key2 = url.searchParams.get("key2");

  if (!key || !key2) {
    showGenericErrorMessageForAnyFormField("Invalid link.", errorEl, input);
    return;
  }
      
  clearErrorMessageForAnyFormField(errorEl, input);
  return ({'staus': true, 'key': key, 'key2': key2});
}


function handleConfirmResetLink() {
  const constStatusAndKeys = validateConfirmResetLink();
  if (constStatusAndKeys?.staus)
  {
    window.open(`${window.location.origin}/ui/punchout/v2/myaccount/confirmresetpassword?key=${encodeURIComponent(constStatusAndKeys?.key)}&key2=${encodeURIComponent(constStatusAndKeys?.key2)}`, "_blank", "noopener,noreferrer");
  }
}

// Just send message to be shown and error contain and field which has error
function showGenericErrorMessageForAnyFormField(message, errorEl, el=null) {
  if (errorEl) {
    errorEl.innerHTML = `<div class="flex items-start gap-2 mt-2 text-sm error-text-color">
        <i class="fas fa-exclamation-circle mt-0.5 shrink-0"></i>
        <span>${message}</span>
      </div>`;
    errorEl.classList.remove("hidden");
  }
  if(el !== null) {
    el?.classList?.add('!tw-border-error-red');
    el?.classList?.add('!tw-text-error-red');
    el?.classList?.remove('account-admin-form-input-field-border');
    el?.nextElementSibling?.classList?.add('!tw-text-error-red')
  }
}

  // clears error if valid. Send error element and element
  function clearErrorMessageForAnyFormField(emailErrorDisplayArea, el) {
    emailErrorDisplayArea.innerHTML = "";
    el?.classList?.remove('!tw-border-error-red');
    el?.classList?.remove('!tw-text-error-red');
    el?.classList?.add('account-admin-form-input-field-border');
    el?.nextElementSibling?.classList?.remove('!tw-text-error-red')
  }


// blocks hx-post if invalid
  function validateFpEmailOnSubmit(event) {
    const emailFp = document.getElementById("email1").value.trim();
    if (!isValidAnyEmail(emailFp)) {
      event.preventDefault(); 
      return false;
    }
  }

  // check if any email is valid
  function isValidAnyEmail(email) {
    // Practical RFC‑compliant regex (safe for frontend)
    const emailRegex =
      /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/;
    return emailRegex.test(email);
  }

 // generic email validator
  function validateAnyEmailAddress(event, emailErrorContainerId){
    const emailInput = document.getElementById(event?.target?.id);
    const email = emailInput.value.trim();
    const emailErrorDisplayArea = document.getElementById(emailErrorContainerId);
    if (!email) {
      showGenericErrorMessageForAnyFormField("Email is a required field", emailErrorDisplayArea, emailInput);
      return false;
    }

    if (!isValidAnyEmail(email)) {
      showGenericErrorMessageForAnyFormField("Email is an invalid email address", emailErrorDisplayArea, emailInput);
      return false;
    }

    clearErrorMessageForAnyFormField(emailErrorDisplayArea, emailInput);
    return true;
  }
  // generic email blur handler
  function handleAnyEmailBlur(event, emailErrorContainerId) {
    validateAnyEmailAddress(event, emailErrorContainerId);
  }

// validate confirm reset before submit
  function validateConfirmResetForm(event) {
    // Force final validation
    const checkValidEmail = validateEmail();
    const checkValidPassword = validateCurrentPassword();
    const checkValidConfirmPassword = validateConfirmPassword();

    if (!(checkValidEmail && checkValidPassword && checkValidConfirmPassword)) {
        event.preventDefault(); // stops HTMX request
        return false;
    }

    return true; // allows HTMX submit
}

// reset success and failure handler
function handleConfirmResetResponse(event) {
    const isSuccess = event.detail.successful;

    const successEl = document.querySelector('#reset-success p');
    const errorEl = document.querySelector('#reset-error p');

    // Always reset state first
    successEl.classList.add('hidden');
    errorEl.classList.add('hidden');

    if (isSuccess) {
        successEl.classList.remove('hidden');
    } else {
        errorEl.classList.remove('hidden');
    }
}

// valite signin frm onsubmit
function validateSfEmailOnSubmit(event) {
  const emailInput = document.getElementById("email2");
  const passwordInput = document.getElementById("credential2");

  const emailError = document.getElementById("email-error-container-sf");
  const credentialError = document.getElementById("credential-error-container-sf");

  let isValid = true;

  // Reset errors
  emailError.innerHTML = "";
  credentialError.innerHTML = "";
  clearErrorMessageForAnyFormField(emailError, emailInput);
  clearErrorMessageForAnyFormField(credentialError, passwordInput);

  // Email validation
  if (!emailInput.value.trim()) {
    showGenericErrorMessageForAnyFormField("Email is required", emailError, emailInput);
    isValid = false;
  }

  // Password validation
  if (!passwordInput.value.trim()) {
    showGenericErrorMessageForAnyFormField("Password is required", credentialError, passwordInput);
    isValid = false;
  }


  // Prevent submit if invalid
  if (!isValid) {
    event.preventDefault();
    return false;
  }

  return true;
}

// signin drawer error scenario
function handleSignInDrawerError(event) {
  const credentialError = document.getElementById("credential-error-container-sf");

  let errorMessage = "Invalid email or password";

  try {
    const response = event.detail.xhr.response;

    // If API returns JSON
    const parsed = JSON.parse(response);
    if (parsed?.message) {
      showGenericErrorMessageForAnyFormField(errorMessage, credentialError);
    }
  } catch (e) {
    // fallback if not JSON
  }

  showGenericErrorMessageForAnyFormField(errorMessage, credentialError);
}

// signin drawer success scenario
function handleSignInSuccess(event) {
  const xhr = event.detail.xhr;

  // Only handle success responses
  if (xhr.status !== 200) return;

  try {
    const response = JSON.parse(xhr.responseText);

    if (response?.cookieName && response?.cookieValue) {
      // Set cookie on browser. Please Note: except for the first gac cookie which is needed for gigya, no other cookies should be used for SSR development. These cookies are added so that it will work in react when converted to extrinsic user. After extrinsic SSR conversion these cookies will be deleated.
      document.cookie = `${response.cookieName}=${response.cookieValue}; path=/; secure; SameSite=None`;
      document.cookie = `WCDE_PUNCHOUT_INTRENSIC=false; path=/; secure; SameSite=None`;
      document.cookie = "WCDE_SHOPPING_MODE=; path=/; Max-Age=-1; secure; SameSite=None";
      document.cookie = "WCDE_UID=undefined; path=/; secure; SameSite=None";
      document.cookie = "WCDE_UID_ACTIVE=; path=/; Max-Age=-1; secure; SameSite=None";
      document.cookie = "WCDE_UI_APPS=; path=/; Max-Age=-1; secure; SameSite=None";
      document.cookie = "WCDE_PUNCHOUT_EDIT_CART=false; path=/; secure; SameSite=None";
      // Redirect after success
      const referrer = window?.location?.pathname+window?.location?.search;

      window.location.href = `/ui/punchout/myaccount?v2referrer=${encodeURIComponent(referrer)}`;
    }

  } catch (e) {
    console.error("Error parsing response:", e);
  }
}

