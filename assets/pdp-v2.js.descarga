const handleFdQtyInput = () => {
  const fdQtyInput = f('#fd-modal-qty-input')
  if (fdQtyInput.value.length > fdQtyInput.maxLength) {
    fdQtyInput.value = fdQtyInput.value.slice(0, fdQtyInput.maxLength);
  }
  if (fdQtyInput.value.trim() === '' || parseFloat(fdQtyInput.value) < 1) {
    fdQtyInput.classList.add('errorClass');
    const fdAddToCartBtn = f('#fd-addtocart');
    if(fdAddToCartBtn) {
      fdAddToCartBtn.disabled = true;
    }
  } else {
    fdQtyInput.classList.remove('errorClass');
  }
}

const handleFdQtyUpdate = (price) => {
  const fdQtyInput = f("#fd-modal-qty-input");
  const fdAddToCartBtn = f("#fd-addtocart");
  const totalPriceEl = f("#fd-modal-lowest-price");
  if (fdQtyInput.value.length > fdQtyInput.maxLength) {
    fdQtyInput.value = fdQtyInput.value.slice(0, fdQtyInput.maxLength);
  }
  // if empty or non valid input like zero, we will add error class to input and set single item price
  if (fdQtyInput.value.trim() === "" || parseFloat(fdQtyInput.value) < 1) {
    fdQtyInput.classList.add("errorClass");
    const singlePriceValue = f("#fd-priceDisplayValue");
    if (totalPriceEl) {
      totalPriceEl.innerText = singlePriceValue?.value;
    }
    if (fdAddToCartBtn) {
      fdAddToCartBtn.disabled = true;
    }
  } else {
    fdQtyInput.classList.remove("errorClass");
    if (fdAddToCartBtn) {
      fdAddToCartBtn.disabled = false;
    }
    const cartResponseMsgEl = f("#add-to-cart-response");
    if (cartResponseMsgEl.firstChild) {
      cartResponseMsgEl.removeChild(cartResponseMsgEl.firstChild);
      // making add to cart btn visible on qty update since we made hidden on after request of AddToCart API call
      // so user can add item to cart again
      if (fdAddToCartBtn) {
        fdAddToCartBtn?.classList.remove("hidden");
      }
    }
    const qty = Number(fdQtyInput.value);
    let totalPrice = Number(qty * Number(price)).toFixed(2);
    const qtyPriceEl = f(".fd-tier-list-price");

    // if product has quantity break prices, making price bold for updated qty range price
    if (qtyPriceEl.length > 0) {
      const fdBreakPriceListScriptId = f("#fd-script-data");
      // getting qty break pricing json data from ldScript
      const { quantityBreakPriceList } = JSON.parse(
        fdBreakPriceListScriptId.textContent
      );
      const matchedQtyPriceObj = quantityBreakPriceList.find(
        ({ fromQuantity, toQuantity }) =>
          qty >= fromQuantity && qty <= toQuantity
      );
      // matching with all price fields of tier price table
      qtyPriceEl.forEach((ele) => {
        ele.classList.remove("font-bold");
        if (ele.innerText == matchedQtyPriceObj?.priceDisplayText) {
          totalPrice = Number(qty * Number(matchedQtyPriceObj?.price)).toFixed(
            2
          );
          ele.classList.add("font-bold");
        }
      });
    }
    if (totalPriceEl) {
      // updating total price value into DOM
      const totalPriceValueEl = f("#fd-total-cart-price");
      const totalPriceText = "$" + utils.formatNumberWithCommas(totalPrice);
      totalPriceValueEl.value = totalPrice;
      totalPriceEl.innerText = totalPriceText;
    }
  }
};

